# =============================================================================
# FB POSTER — 環境界面設定檔 (.env)
# =============================================================================
# 複製此檔為 .env 並填入你的設定值
# 所有 API key 都支援 mock 模式（設定為 MOCK 即可在本機測試）
# =============================================================================

# ── 發文設定 ──
POST_INTERVAL_MIN=60
POST_INTERVAL_MAX=360
DELETE_AFTER_HOURS=24
AUTO_CLEAN_HOUR=3
AUTO_CLEAN_MINUTE=0

# ── Ollama (本機 AI) ──
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── OpenAI / GPT (備用，可 mock) ──
OPENAI_API_KEY=MOCK
OPENAI_MODEL=gpt-4.1-mini
GPT_SERVER_URL=http://localhost:5000/api/gpt

# ── Facebook Graph API ──
FB_APP_ID=MOCK
FB_APP_SECRET=MOCK
FB_PAGE_ACCESS_TOKEN=MOCK

# ── Telegram Bot ──
TELEGRAM_BOT_TOKEN=MOCK

# ── TikTok ──
TIKTOK_SESSION_ID=MOCK

# ── 網站部署 ──
VERCEL_PROJECT_NAME=fb-property-site
VERCEL_TOKEN=MOCK

# ── 安全性 ──
SECRET_KEY=dev-secret-change-in-production
LICENSE_HMAC_KEY=dev-hmac-key-change-in-production
